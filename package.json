{
  "name": "job-tune",
  "version": "2.0.0",
  "private": true,
  "description": "Strict-TypeScript migration of Job Tune with a Next.js web app and Node queue worker.",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev:web",
    "dev:web": "node scripts/run-development.mjs web",
    "dev:worker": "node scripts/run-development.mjs worker",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:all": "npm run lint && npm run typecheck && npm test && npm run build",
    "audit:dependencies": "npm audit --omit=dev --audit-level=critical",
    "db:migrate": "npm run migrate --workspace @job/db",
    "db:rollback": "npm run rollback --workspace @job/db",
    "db:verify": "npm run verify --workspace @job/db",
    "db:characterize": "npm run characterize --workspace @job/db",
    "db:queue-status": "npm run queue-status --workspace @job/db",
    "retention:purge": "npm run purge --workspace @job/db"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "@types/tabulator-tables": "^6.3.6",
    "eslint": "^9.32.0",
    "eslint-config-next": "16.2.11",
    "globals": "^16.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.2.4"
  }
}
