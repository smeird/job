[Unit]
Description=Job Tune retention purge
After=network-online.target mysql.service
Wants=network-online.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/srv/job/current
EnvironmentFile=/etc/job/job.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /srv/job/current/packages/db/dist/cli.js purge
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/log/job
