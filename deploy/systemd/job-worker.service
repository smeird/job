[Unit]
Description=Job Tune TypeScript queue worker
After=network-online.target mysql.service
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/srv/job/current
EnvironmentFile=/etc/job/job.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /srv/job/current/apps/worker/dist/index.js
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/log/job

[Install]
WantedBy=multi-user.target
